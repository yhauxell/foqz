{
  "name": "foqz",
  "version": "0.1.0",
  "private": true,
  "description": "Foqz — tray toggle, tldraw canvas, and focus timers",
  "author": "Foqz",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "vite build",
    "build:landing": "vite build --config vite.landing.config.ts && node ./scripts/landing-copy-index.mjs",
    "dev:landing": "vite --config vite.landing.config.ts",
    "preview:landing": "vite preview --config vite.landing.config.ts",
    "start": "electron .",
    "dist": "vite build && electron-builder --publish never",
    "dist:dir": "vite build && electron-builder --dir --publish never",
    "dist:publish": "vite build && electron-builder --publish always"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@tldraw/tldraw": "^3.9.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.4",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.2",
    "vite": "^5.4.11",
    "wait-on": "^8.0.3"
  }
}
